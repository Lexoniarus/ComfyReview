<+>{% extends \"_base.html\" %}\r\n{% set page_title = \"Playground\" %}\r\n\r\n{% block head %}\r\n<style>\r\n  .grid2{ display:grid; grid-template-columns: 1fr 1fr; gap:12px; }\r\n  .grid1{ display:grid; grid-template-columns: 1fr; gap:10px; }\r\n  .hint{ color:var(--muted); font-size:12px; margin-top:6px; }\r\n  .mono{\r\n    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;\r\n    white-space: pre-wrap;\r\n    word-break: break-word;\r\n  }\r\n  textarea, select, input{\r\n    width:100%;\r\n    background: rgba(0,0,0,0.45);\r\n    color: rgba(255,255,255,0.9);\r\n    border:1px solid var(--border);\r\n    border-radius:12px;\r\n    padding:10px;\r\n    box-sizing:border-box;\r\n  }\r\n  textarea{ min-height:84px; }\r\n  .rowActions{ display:flex; gap:8px; flex-wrap:wrap; align-items:center; }\r\n  details > summary{ cursor:pointer; }\r\n  .pillSmall{\r\n    display:inline-block;\r\n    padding:2px 8px;\r\n    border:1px solid var(--border);\r\n    border-radius:999px;\r\n    font-size:12px;\r\n    color: var(--muted);\r\n  }\r\n  img.preview{\r\n    max-height: 90px;\r\n    max-width: 160px;\r\n    border-radius: 10px;\r\n    border: 1px solid var(--border);\r\n    object-fit: contain;\r\n    display:block;\r\n    margin-top: 6px;\r\n  }\r\n</style>\r\n{% endblock %}\r\n\r\n{% block body %}\r\n\r\n<div class=\"top\">\r\n  <div>\r\n    <div style=\"display:flex; gap:10px; flex-wrap:wrap;\">\r\n      <div class=\"pill\">Playground</div>\r\n      <div class=\"pill\">Bausteine</div>\r\n      <div class=\"pill\">Pos und Neg getrennt</div>\r\n    </div>\r\n    <div class=\"hint\">\r\n      Builder Datenbasis fuer Generator. Kein Log. Hard delete.\r\n    </div>\r\n  </div>\r\n  {% include \"_nav.html\" %}\r\n</div>\r\n\r\n<form class=\"filter\" method=\"get\" action=\"/playground\">\r\n  <label class=\"small\">Kategorie</label>\r\n  <select name=\"kind\">\r\n    <option value=\"\" {% if not kind %}selected{% endif %}>alle</option>\r\n    <option value=\"character\" {% if kind==\"character\" %}selected{% endif %}>Charakter</option>\r\n    <option value=\"scene\" {% if kind==\"scene\" %}selected{% endif %}>Szene</option>\r\n    <option value=\"outfit\" {% if kind==\"outfit\" %}selected{% endif %}>Outfit</option>\r\n    <option value=\"modifier\" {% if kind==\"modifier\" %}selected{% endif %}>Modifier</option>\r\n    <option value=\"pose\" {% if kind==\"pose\" %}selected{% endif %}>Pose</option>\r\n    <option value=\"expression\" {% if kind==\"expression\" %}selected{% endif %}>Ausdruck</option>\r\n    <option value=\"lighting\" {% if kind==\"lighting\" %}selected{% endif %}>Licht</option>\r\n  </select>\r\n\r\n  <label class=\"small\">Suche</label>\r\n  <input type=\"text\" name=\"q\" value=\"{{ q }}\" placeholder=\"name, key, tags\">\r\n  <button type=\"submit\">anwenden</button>\r\n  <a href=\"/playground\">reset</a>\r\n</form>\r\n\r\n<div class=\"box\" style=\"margin-top:14px;\">\r\n  <h3>Neuen Baustein anlegen</h3>\r\n\r\n  <form method=\"post\" action=\"/playground/create\" class=\"grid1\" id=\"createForm\">\r\n\r\n    <div class=\"grid2\">\r\n      <div>\r\n        <div class=\"small\">Kategorie</div>\r\n        <select name=\"kind\" required>\r\n          <option value=\"\" disabled selected>bitte waehlen</option>\r\n          <option value=\"character\">Charakter</option>\r\n          <option value=\"scene\">Szene</option>\r\n          <option value=\"outfit\">Outfit</option>\r\n          <option value=\"modifier\">Modifier</option>\r\n          <option value=\"pose\">Pose</option>\r\n          <option value=\"expression\">Ausdruck</option>\r\n          <option value=\"lighting\">Licht</option>\r\n        </select>\r\n      </div>\r\n\r\n      <div>\r\n        <div class=\"small\">Name</div>\r\n        <input name=\"name\" placeholder=\"Rooftop School\" required>\r\n      </div>\r\n    </div>\r\n\r\n    <div>\r\n      <div class=\"small\">Tags</div>\r\n      <input name=\"tags\" placeholder=\"school, rooftop, outdoor\">\r\n      <div class=\"hint\">Komma getrennt, fuer Filter und spaeter Generator</div>\r\n    </div>\r\n\r\n    <div>\r\n      <div class=\"small\">Positiv Prompt</div>\r\n      <textarea name=\"pos\" rows=\"3\" id=\"create_pos\"></textarea>\r\n      <div id=\"create_pos_stats\" class=\"hint mono\"></div>\r\n    </div>\r\n\r\n    <div>\r\n      <div class=\"small\">Negativ Prompt</div>\r\n      <textarea name=\"neg\" rows=\"3\" id=\"create_neg\"></textarea>\r\n      <div id=\"create_neg_stats\" class=\"hint mono\"></div>\r\n    </div>\r\n\r\n    <div>\r\n      <div class=\"small\">Notizen</div>\r\n      <textarea name=\"notes\" rows=\"2\"></textarea>\r\n    </div>\r\n\r\n    <div class=\"rowActions\">\r\n      <button type=\"submit\">anlegen</button>\r\n    </div>\r\n  </form>\r\n</div>\r\n\r\n<div class=\"box\" style=\"margin-top:20px;\">\r\n  <h3>Eintraege</h3>\r\n  <div class=\"hint\">Tabelle sortierbar, Header klicken.</div>\r\n\r\n  <table class=\"sortable\">\r\n    <tr>\r\n      <th>kategorie</th>\r\n      <th>name</th>\r\n      <th>key</th>\r\n      <th>tags</th>\r\n      <th>pos</th>\r\n      <th>neg</th>\r\n      <th>match</th>\r\n      <th>actions</th>\r\n    </tr>\r\n\r\n    {% for r in rows %}\r\n    <tr>\r\n      <td>{{ r[\"kind\"] }}</td>\r\n      <td>{{ r[\"name\"] }}</td>\r\n      <td class=\"mono\">{{ r[\"key\"] }}</td>\r\n      <td>{{ r[\"tags\"] }}</td>\r\n\r\n      <td class=\"mono\" style=\"max-width:360px;\">{{ r[\"pos\"] }}</td>\r\n      <td class=\"mono\" style=\"max-width:360px;\">{{ r[\"neg\"] }}</td>\r\n\r\n      <td style=\"min-width:240px;\">\r\n        {% set bm = r[\"best_match\"] %}\r\n        {% if bm %}\r\n          <div class=\"pillSmall\">\r\n            hits {{ bm[\"hits\"] }}\r\n            {% if bm[\"avg_rating\"] is not none %}\r\n              avg {{ \"%.2f\"|format(bm[\"avg_rating\"]) }}\r\n            {% else %}\r\n              avg n/a\r\n            {% endif %}\r\n            runs {{ bm[\"runs\"] }}\r\n          </div>\r\n\r\n          {% if bm.get(\"url\") %}\r\n            <a href=\"{{ bm['url'] }}\" target=\"_blank\">\r\n              <img class=\"preview\" src=\"{{ bm['url'] }}\">\r\n            </a>\r\n          {% else %}\r\n            <div class=\"hint mono\">kein png_path join</div>\r\n          {% endif %}\r\n        {% else %}\r\n          <div class=\"hint\">no match</div>\r\n        {% endif %}\r\n      </td>\r\n\r\n      <td style=\"min-width:240px;\">\r\n        <details>\r\n          <summary>edit</summary>\r\n\r\n          <form method=\"post\" action=\"/playground/update\" class=\"grid1\" style=\"margin-top:10px;\">\r\n            <input type=\"hidden\" name=\"item_id\" value=\"{{ r['id'] }}\">\r\n\r\n            <div class=\"grid2\">\r\n              <div>\r\n                <div class=\"small\">Kategorie</div>\r\n                <select name=\"kind\" required>\r\n                  <option value=\"character\" {% if r[\"kind\"]==\"character\" %}selected{% endif %}>Charakter</option>\r\n                  <option value=\"scene\" {% if r[\"kind\"]==\"scene\" %}selected{% endif %}>Szene</option>\r\n                  <option value=\"outfit\" {% if r[\"kind\"]==\"outfit\" %}selected{% endif %}>Outfit</option>\r\n                  <option value=\"modifier\" {% if r[\"kind\"]==\"modifier\" %}selected{% endif %}>Modifier</option>\r\n                  <option value=\"pose\" {% if r[\"kind\"]==\"pose\" %}selected{% endif %}>Pose</option>\r\n                  <option value=\"expression\" {% if r[\"kind\"]==\"expression\" %}selected{% endif %}>Ausdruck</option>\r\n                  <option value=\"lighting\" {% if r[\"kind\"]==\"lighting\" %}selected{% endif %}>Licht</option>\r\n                </select>\r\n              </div>\r\n\r\n              <div>\r\n                <div class=\"small\">Name</div>\r\n                <input name=\"name\" value=\"{{ r['name'] }}\" required>\r\n              </div>\r\n            </div>\r\n\r\n            <div>\r\n              <div class=\"small\">Tags</div>\r\n              <input name=\"tags\" value=\"{{ r['tags'] }}\">\r\n            </div>\r\n\r\n            <div>\r\n              <div class=\"small\">Positiv Prompt</div>\r\n              <textarea name=\"pos\" rows=\"3\" class=\"edit_pos\" data-id=\"{{ r['id'] }}\">{{ r['pos'] }}</textarea>\r\n              <div id=\"edit_pos_stats_{{ r['id'] }}\" class=\"hint mono\"></div>\r\n            </div>\r\n\r\n            <div>\r\n              <div class=\"small\">Negativ Prompt</div>\r\n              <textarea name=\"neg\" rows=\"3\" class=\"edit_neg\" data-id=\"{{ r['id'] }}\">{{ r['neg'] }}</textarea>\r\n              <div id=\"edit_neg_stats_{{ r['id'] }}\" class=\"hint mono\"></div>\r\n            </div>\r\n\r\n            <div>\r\n              <div class=\"small\">Notizen</div>\r\n              <textarea name=\"notes\" rows=\"2\">{{ r['notes'] }}</textarea>\r\n            </div>\r\n\r\n            <div class=\"rowActions\">\r\n              <button type=\"submit\">speichern</button>\r\n            </div>\r\n          </form>\r\n        </details>\r\n\r\n        <form method=\"post\" action=\"/playground/delete\" style=\"margin-top:8px;\">\r\n          <input type=\"hidden\" name=\"item_id\" value=\"{{ r['id'] }}\">\r\n          <button class=\"danger\" type=\"submit\">loeschen</button>\r\n        </form>\r\n      </td>\r\n    </tr>\r\n    {% endfor %}\r\n  </table>\r\n</div>\r\n\r\n<script>\r\n  function splitTokens(text){\r\n    return (text || \"\")\r\n      .split(\",\")\r\n      .map(t => t.trim())\r\n      .filter(Boolean);\r\n  }\r\n\r\n  async function fetchStats(scope, tokens){\r\n    if(!tokens || tokens.length === 0) return {};\r\n    const res = await fetch(\"/playground/token_stats\", {\r\n      method: \"POST\",\r\n      headers: {\"Content-Type\": \"application/json\"},\r\n      body: JSON.stringify({\r\n        scope: scope,\r\n        tokens: tokens,\r\n        model_branch: \"\"\r\n      })\r\n    });\r\n    if(!res.ok) return {};\r\n    const data = await res.json();\r\n    return data.stats || {};\r\n  }\r\n\r\n  function formatStats(stats, tokens){\r\n    if(!tokens.length) return \"\";\r\n    const lines = [];\r\n    for(const t of tokens){\r\n      const s = stats[t];\r\n      if(!s){\r\n        lines.push(`${t}: n=0 mean=0.00 lb05=0.00`);\r\n      } else {\r\n        lines.push(`${t}: n=${s.n} mean=${Number(s.mean).toFixed(2)} lb05=${Number(s.lb05).toFixed(2)}`);\r\n      }\r\n    }\r\n    return lines.join(\"\\\\n\");\r\n  }\r\n\r\n  function debounce(fn, ms){\r\n    let h = null;\r\n    return (...args) => {\r\n      if(h) clearTimeout(h);\r\n      h = setTimeout(() => fn(...args), ms);\r\n    };\r\n  }\r\n\r\n  const createPos = document.getElementById(\"create_pos\");\r\n  const createNeg = document.getElementById(\"create_neg\");\r\n  const createPosStats = document.getElementById(\"create_pos_stats\");\r\n  const createNegStats = document.getElementById(\"create_neg_stats\");\r\n\r\n  const updateCreatePos = debounce(async () => {\r\n    const toks = splitTokens(createPos.value);\r\n    const stats = await fetchStats(\"pos\", toks);\r\n    createPosStats.textContent = formatStats(stats, toks);\r\n  }, 350);\r\n\r\n  const updateCreateNeg = debounce(async () => {\r\n    const toks = splitTokens(createNeg.value);\r\n    const stats = await fetchStats(\"neg\", toks);\r\n    createNegStats.textContent = formatStats(stats, toks);\r\n  }, 350);\r\n\r\n  if(createPos) createPos.addEventListener(\"input\", updateCreatePos);\r\n  if(createNeg) createNeg.addEventListener(\"input\", updateCreateNeg);\r\n\r\n  const editPosAreas = document.querySelectorAll(\"textarea.edit_pos\");\r\n  const editNegAreas = document.querySelectorAll(\"textarea.edit_neg\");\r\n\r\n  const updateEditPos = debounce(async (id, value) => {\r\n    const toks = splitTokens(value);\r\n    const stats = await fetchStats(\"pos\", toks);\r\n    const el = document.getElementById(`edit_pos_stats_${id}`);\r\n    if(el) el.textContent = formatStats(stats, toks);\r\n  }, 350);\r\n\r\n  const updateEditNeg = debounce(async (id, value) => {\r\n    const toks = splitTokens(value);\r\n    const stats = await fetchStats(\"neg\", toks);\r\n    const el = document.getElementById(`edit_neg_stats_${id}`);\r\n    if(el) el.textContent = formatStats(stats, toks);\r\n  }, 350);\r\n\r\n  editPosAreas.forEach(a => {\r\n    const id = a.getAttribute(\"data-id\");\r\n    a.addEventListener(\"input\", () => updateEditPos(id, a.value));\r\n  });\r\n\r\n  editNegAreas.forEach(a => {\r\n    const id = a.getAttribute(\"data-id\");\r\n    a.addEventListener(\"input\", () => updateEditNeg(id, a.value));\r\n  });\r\n</script>\r\n\r\n{% endblock %}
