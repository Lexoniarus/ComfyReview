<+>{# templates/playground_generator.html #}\r\n{% extends \"_base.html\" %}\r\n{% set page_title = \"Playground Generator\" %}\r\n\r\n{% block head %}\r\n<style>\r\n  .grid2{ display:grid; grid-template-columns: 1fr 1fr; gap:12px; }\r\n  .grid3{ display:grid; grid-template-columns: 1fr 1fr 1fr; gap:12px; }\r\n  .grid1{ display:grid; grid-template-columns: 1fr; gap:10px; }\r\n\r\n  .hint{ color:var(--muted); font-size:12px; margin-top:6px; }\r\n  .mono{\r\n    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;\r\n    white-space: pre-wrap;\r\n  }\r\n\r\n  .kpiRow{ display:flex; gap:12px; flex-wrap:wrap; margin-top:10px; }\r\n  .kpi{\r\n    border: 1px solid var(--border);\r\n    background: var(--card);\r\n    border-radius: 12px;\r\n    padding: 10px 12px;\r\n    min-width: 140px;\r\n  }\r\n  .kpi .k{ font-size:12px; color:var(--muted); }\r\n  .kpi .v{ font-size:18px; font-weight:700; }\r\n\r\n  .chip{\r\n    display:inline-block;\r\n    border: 1px solid var(--border);\r\n    background: var(--card);\r\n    border-radius: 999px;\r\n    padding: 6px 10px;\r\n    margin: 4px 6px 0 0;\r\n    font-size: 12px;\r\n  }\r\n\r\n  .boxSub{\r\n    border: 1px solid var(--border);\r\n    background: var(--card);\r\n    border-radius: 12px;\r\n    padding: 12px;\r\n  }\r\n\r\n  textarea{\r\n    width:100%;\r\n    min-height:120px;\r\n    resize: vertical;\r\n    border-radius: 10px;\r\n    border: 1px solid var(--border);\r\n    padding: 10px;\r\n    background: var(--bg);\r\n    color: var(--text);\r\n  }\r\n\r\n  .rowActions{ display:flex; gap:10px; align-items:center; }\r\n  .btnRow{ display:flex; gap:10px; }\r\n  .btnSmall{\r\n    padding: 6px 10px;\r\n    border-radius: 10px;\r\n    border: 1px solid var(--border);\r\n    background: var(--bg);\r\n    color: var(--text);\r\n    cursor: pointer;\r\n    font-size: 12px;\r\n  }\r\n\r\n  .err{\r\n    border: 1px solid #5b1f2a;\r\n    background: #2b1218;\r\n    color: #ffd4dc;\r\n    border-radius: 12px;\r\n    padding: 10px 12px;\r\n  }\r\n\r\n  .ok{\r\n    border: 1px solid var(--border);\r\n    background: var(--card);\r\n    border-radius: 12px;\r\n    padding: 12px;\r\n  }\r\n\r\n  .small{ font-size:12px; color:var(--muted); }\r\n</style>\r\n{% endblock %}\r\n\r\n{% block content %}\r\n<div class=\"panel\">\r\n\r\n  <h1>Playground Generator</h1>\r\n\r\n  <div class=\"hint\">\r\n    Slots ausser Character sind optional.\r\n    Leer bedeutet random.\r\n    Prompts sind Komma getrennt, keine Space Split Logik.\r\n  </div>\r\n\r\n  <div style=\"margin-top:12px;\">\r\n    <form method=\"post\" action=\"/playground/generator\" class=\"grid1\">\r\n\r\n      <div class=\"grid2\">\r\n        <div>\r\n          <div class=\"small\">Character (Pflicht)</div>\r\n          <select name=\"character_id\" required>\r\n            <option value=\"\" disabled {% if not form.character_id %}selected{% endif %}>bitte waehlen</option>\r\n            {% for c in characters %}\r\n              <option value=\"{{ c['id'] }}\" {% if form.character_id == (c['id'] ~ '') %}selected{% endif %}>\r\n                {{ c['name'] }}\r\n              </option>\r\n            {% endfor %}\r\n          </select>\r\n          <div class=\"hint\">Dieser Slot ist fix, damit Rules und Adult Checks stabil greifen.</div>\r\n        </div>\r\n\r\n        <div>\r\n          <div class=\"small\">Seed (optional, reproduzierbar)</div>\r\n          <input name=\"seed\" value=\"{{ form.seed }}\" placeholder=\"zB 12345\">\r\n          <div class=\"hint\">Leer bedeutet normal random. Zahl bedeutet reproduzierbar.</div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"grid3\">\r\n        <div>\r\n          <div class=\"small\">Scene</div>\r\n          <select name=\"scene_id\">\r\n            <option value=\"\" {% if not form.scene_id %}selected{% endif %}>random</option>\r\n            {% for s in scenes %}\r\n              <option value=\"{{ s['id'] }}\" {% if form.scene_id == (s['id'] ~ '') %}selected{% endif %}>{{ s['name'] }}</option>\r\n            {% endfor %}\r\n          </select>\r\n        </div>\r\n\r\n        <div>\r\n          <div class=\"small\">Outfit</div>\r\n          <select name=\"outfit_id\">\r\n            <option value=\"\" {% if not form.outfit_id %}selected{% endif %}>random</option>\r\n            {% for s in outfits %}\r\n              <option value=\"{{ s['id'] }}\" {% if form.outfit_id == (s['id'] ~ '') %}selected{% endif %}>{{ s['name'] }}</option>\r\n            {% endfor %}\r\n          </select>\r\n        </div>\r\n\r\n        <div>\r\n          <div class=\"small\">Pose</div>\r\n          <select name=\"pose_id\">\r\n            <option value=\"\" {% if not form.pose_id %}selected{% endif %}>random</option>\r\n            {% for s in poses %}\r\n              <option value=\"{{ s['id'] }}\" {% if form.pose_id == (s['id'] ~ '') %}selected{% endif %}>{{ s['name'] }}</option>\r\n            {% endfor %}\r\n          </select>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"grid3\">\r\n        <div>\r\n          <div class=\"small\">Expression</div>\r\n          <select name=\"expression_id\">\r\n            <option value=\"\" {% if not form.expression_id %}selected{% endif %}>random</option>\r\n            {% for s in expressions %}\r\n              <option value=\"{{ s['id'] }}\" {% if form.expression_id == (s['id'] ~ '') %}selected{% endif %}>{{ s['name'] }}</option>\r\n            {% endfor %}\r\n          </select>\r\n        </div>\r\n\r\n        <div>\r\n          <div class=\"small\">Lighting</div>\r\n          <select name=\"lighting_id\">\r\n            <option value=\"\" {% if not form.lighting_id %}selected{% endif %}>random</option>\r\n            {% for s in lightings %}\r\n              <option value=\"{{ s['id'] }}\" {% if form.lighting_id == (s['id'] ~ '') %}selected{% endif %}>{{ s['name'] }}</option>\r\n            {% endfor %}\r\n          </select>\r\n        </div>\r\n\r\n        <div>\r\n          <div class=\"small\">Modifier</div>\r\n          <select name=\"modifier_id\">\r\n            <option value=\"\" {% if not form.modifier_id %}selected{% endif %}>random</option>\r\n            {% for s in modifiers %}\r\n              <option value=\"{{ s['id'] }}\" {% if form.modifier_id == (s['id'] ~ '') %}selected{% endif %}>{{ s['name'] }}</option>\r\n            {% endfor %}\r\n          </select>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"grid2\">\r\n        <div>\r\n          <div class=\"small\">include lighting</div>\r\n          <select name=\"include_lighting\">\r\n            <option value=\"1\" {% if form.include_lighting %}selected{% endif %}>yes</option>\r\n            <option value=\"0\" {% if not form.include_lighting %}selected{% endif %}>no</option>\r\n          </select>\r\n          <div class=\"hint\">Wenn no, wird Lighting ignoriert, auch wenn ausgewaehlt.</div>\r\n        </div>\r\n\r\n        <div>\r\n          <div class=\"small\">include modifier</div>\r\n          <select name=\"include_modifier\">\r\n            <option value=\"1\" {% if form.include_modifier %}selected{% endif %}>yes</option>\r\n            <option value=\"0\" {% if not form.include_modifier %}selected{% endif %}>no</option>\r\n          </select>\r\n          <div class=\"hint\">Wenn no, wird Modifier ignoriert, auch wenn ausgewaehlt.</div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"grid2\">\r\n        <div>\r\n          <div class=\"small\">max tries</div>\r\n          <input name=\"max_tries\" type=\"number\" min=\"1\" value=\"{{ form.max_tries }}\">\r\n          <div class=\"hint\">Reject Loop Limit, wenn Rules viele Kombinationen blocken.</div>\r\n        </div>\r\n\r\n        <div class=\"btnRow\" style=\"align-items:flex-end;\">\r\n          <button type=\"submit\" name=\"action\" value=\"generate\">generieren</button>\r\n          <a href=\"/playground\" class=\"small\">zurueck zu playground</a>\r\n        </div>\r\n      </div>\r\n\r\n    </form>\r\n  </div>\r\n\r\n  {% if error %}\r\n    <div class=\"err\" style=\"margin-top:14px;\">\r\n      <div class=\"mono\">{{ error }}</div>\r\n    </div>\r\n  {% endif %}\r\n\r\n  {% if result %}\r\n    <div class=\"ok\" style=\"margin-top:14px;\">\r\n\r\n      <div class=\"kpiRow\">\r\n        <div class=\"kpi\">\r\n          <div class=\"k\">aktive tags</div>\r\n          <div class=\"v\">{{ (result.get(\"active_tags\") or []) | length }}</div>\r\n        </div>\r\n        <div class=\"kpi\">\r\n          <div class=\"k\">attempt</div>\r\n          <div class=\"v\">{{ result.get(\"debug\", {}).get(\"attempt\", \"\") }}</div>\r\n        </div>\r\n        <div class=\"kpi\">\r\n          <div class=\"k\">seed</div>\r\n          <div class=\"v\">{{ result.get(\"debug\", {}).get(\"seed\", \"\") }}</div>\r\n        </div>\r\n      </div>\r\n\r\n      <div style=\"margin-top:12px;\">\r\n        {% set sel = result.get(\"selection\") %}\r\n        {% if sel %}\r\n          {% for k, v in sel.items() %}\r\n            <span class=\"chip\">{{ k }}: {{ v.get(\"name\") }}</span>\r\n          {% endfor %}\r\n        {% endif %}\r\n      </div>\r\n\r\n      <div class=\"grid2\" style=\"margin-top:12px;\">\r\n        <div class=\"boxSub\">\r\n          <div class=\"small\">Positiv Prompt</div>\r\n          <div class=\"rowActions\" style=\"justify-content:flex-end; margin-top:6px;\">\r\n            <button class=\"btnSmall\" type=\"button\" onclick=\"copyText('pos_prompt')\">copy</button>\r\n          </div>\r\n          <textarea id=\"pos_prompt\" readonly>{{ result.get(\"positive\") }}</textarea>\r\n          <div class=\"hint\">Komma getrennt, so wie eure Token Pflege.</div>\r\n        </div>\r\n\r\n        <div class=\"boxSub\">\r\n          <div class=\"small\">Negativ Prompt</div>\r\n          <div class=\"rowActions\" style=\"justify-content:flex-end; margin-top:6px;\">\r\n            <button class=\"btnSmall\" type=\"button\" onclick=\"copyText('neg_prompt')\">copy</button>\r\n          </div>\r\n          <textarea id=\"neg_prompt\" readonly>{{ result.get(\"negative\") }}</textarea>\r\n          <div class=\"hint\">Komma getrennt, so wie eure Token Pflege.</div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"boxSub\" style=\"margin-top:12px;\">\r\n        <div class=\"small\">Notes</div>\r\n        <textarea readonly>{{ result.get(\"notes\") }}</textarea>\r\n        <div class=\"hint\">Notes sind Lesetext, nicht Prompt Tokens.</div>\r\n      </div>\r\n\r\n      <div class=\"boxSub\" style=\"margin-top:12px;\">\r\n        <div class=\"small\">An ComfyUI uebergeben</div>\r\n        <div class=\"hint\">Absenden nutzt exakt die oben angezeigten Prompts. Es wird dabei nicht erneut generiert.</div>\r\n\r\n        <form method=\"post\" action=\"/playground/generator\" style=\"margin-top:10px;\">\r\n          <input type=\"hidden\" name=\"action\" value=\"submit\">\r\n\r\n          <input type=\"hidden\" name=\"character_id\" value=\"{{ form.character_id }}\">\r\n          <input type=\"hidden\" name=\"scene_id\" value=\"{{ form.scene_id }}\">\r\n          <input type=\"hidden\" name=\"outfit_id\" value=\"{{ form.outfit_id }}\">\r\n          <input type=\"hidden\" name=\"pose_id\" value=\"{{ form.pose_id }}\">\r\n          <input type=\"hidden\" name=\"expression_id\" value=\"{{ form.expression_id }}\">\r\n          <input type=\"hidden\" name=\"lighting_id\" value=\"{{ form.lighting_id }}\">\r\n          <input type=\"hidden\" name=\"modifier_id\" value=\"{{ form.modifier_id }}\">\r\n\r\n          <input type=\"hidden\" name=\"include_lighting\" value=\"{{ 1 if form.include_lighting else 0 }}\">\r\n          <input type=\"hidden\" name=\"include_modifier\" value=\"{{ 1 if form.include_modifier else 0 }}\">\r\n\r\n          <input type=\"hidden\" name=\"seed\" value=\"{{ form.seed }}\">\r\n          <input type=\"hidden\" name=\"max_tries\" value=\"{{ form.max_tries }}\">\r\n\r\n          <input type=\"hidden\" name=\"positive_prompt\" value=\"{{ result.get('positive') }}\">\r\n          <input type=\"hidden\" name=\"negative_prompt\" value=\"{{ result.get('negative') }}\">\r\n\r\n          <div class=\"btnRow\" style=\"margin-top:8px;\">\r\n            <button type=\"submit\">absenden</button>\r\n          </div>\r\n        </form>\r\n\r\n        {% if enqueue %}\r\n          <div class=\"hint mono\" style=\"margin-top:10px; white-space:pre-wrap;\">{{ enqueue }}</div>\r\n        {% endif %}\r\n      </div>\r\n\r\n      <details style=\"margin-top:12px;\">\r\n        <summary class=\"small\">Debug anzeigen</summary>\r\n\r\n        <div class=\"boxSub\" style=\"margin-top:10px;\">\r\n          <div class=\"small\">active tags</div>\r\n          <div class=\"mono\">{{ result.get(\"active_tags\") }}</div>\r\n        </div>\r\n\r\n        <div class=\"boxSub\" style=\"margin-top:10px;\">\r\n          <div class=\"small\">selection</div>\r\n          <div class=\"mono\">{{ result.get(\"selection\") }}</div>\r\n        </div>\r\n\r\n        <div class=\"boxSub\" style=\"margin-top:10px;\">\r\n          <div class=\"small\">debug</div>\r\n          <div class=\"mono\">{{ result.get(\"debug\") }}</div>\r\n        </div>\r\n      </details>\r\n\r\n    </div>\r\n  {% endif %}\r\n\r\n</div>\r\n\r\n<script>\r\n  function copyText(id){\r\n    const el = document.getElementById(id);\r\n    if(!el){ return; }\r\n    el.select();\r\n    document.execCommand(\"copy\");\r\n  }\r\n</script>\r\n{% endblock %}
